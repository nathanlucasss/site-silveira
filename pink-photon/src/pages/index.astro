			.text-button:hover {
				color: var(--color-gold-light);
			}

			.modal {
				position: fixed;
				inset: 0;
				z-index: 1200;
				background: rgba(0, 0, 0, 0.62);
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 20px;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.2s ease;
			}

			.modal.open {
				opacity: 1;
				pointer-events: auto;
			}

			.modal-content {
				width: min(760px, 100%);
				max-height: 85vh;
				overflow: auto;
				border-radius: 8px;
				background: var(--color-white);
				padding: 24px;
				box-shadow: 0 4px 24px rgba(0, 0, 0, 0.16);
				position: relative;
			}

			.modal-content h3 {
				font-size: 30px;
				margin-bottom: 10px;
			}

			.modal-content p {
				margin-bottom: 10px;
			}

			.modal-close {
				position: absolute;
				right: 10px;
				top: 10px;
				width: 44px;
				height: 44px;
				border: 0;
				border-radius: 50%;
				background: var(--color-off-white);
				cursor: pointer;
			}

			.reveal {
				opacity: 0;
				transform: translateY(40px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}

			.reveal.visible {
				opacity: 1;
				transform: translateY(0);
			}

			.reveal:nth-child(1) {
				transition-delay: 0s;
			}

			.reveal:nth-child(2) {
				transition-delay: 0.1s;
			}

			.reveal:nth-child(3) {
				transition-delay: 0.2s;
			}

			.reveal:nth-child(4) {
				transition-delay: 0.3s;
			}

			@keyframes pulse {
				0%,
				100% {
					box-shadow: 0 0 0 0 rgba(184, 150, 62, 0.5);
				}

				50% {
					box-shadow: 0 0 0 12px rgba(184, 150, 62, 0);
				}
			}

			@keyframes heroFadeIn {
				from {
					opacity: 0;
					transform: translateY(20px);
				}

				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

