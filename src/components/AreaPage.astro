---
import Layout from '../layouts/Layout.astro';
import type { AreaContent } from '../data/areas';
import { LOCAL_BUSINESS_LEGAL_SERVICE_SCHEMA } from '../data/structuredData';

interface Props {
	area: AreaContent;
}

const { area } = Astro.props;
const whatsappAreaMessage = encodeURIComponent(`Olá! Preciso de atendimento em ${area.name}`);
const whatsappFromAreaPageMessage = encodeURIComponent(`Olá! Vi a página de ${area.name} e preciso de orientação.`);

const structuredData = [
	LOCAL_BUSINESS_LEGAL_SERVICE_SCHEMA,
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: area.faqs.map((faq) => ({
			'@type': 'Question',
			name: faq.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: faq.answer,
			},
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Início', item: 'https://silveiraadv.com.br/' },
			{
				'@type': 'ListItem',
				position: 2,
				name: 'Áreas de Atuação',
				item: 'https://silveiraadv.com.br/',
			},
			{
				'@type': 'ListItem',
				position: 3,
				name: area.name,
				item: `https://silveiraadv.com.br/areas/${area.slug}`,
			},
		],
	},
];
---

<Layout
	title={area.title}
	description={area.description}
	keywords={`advogado ${area.name.toLowerCase()} campo belo mg, ${area.name.toLowerCase()}, silveira advocacia`}
	canonicalPath={`/areas/${area.slug}`}
	structuredData={structuredData}
>
	<section class="page-hero" aria-labelledby="area-title">
		<div class="container">
			<div class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Início</a>
				<span>/</span>
				<a href="/">Áreas</a>
				<span>/</span>
				<span>{area.name}</span>
			</div>
			<p class="page-kicker">{area.kicker}</p>
			<h1 id="area-title">{area.h1}</h1>
			<p>{area.intro}</p>
			<div class="page-actions">
				<a
					href={`https://wa.me/5535998481800?text=${whatsappAreaMessage}`}
					class="btn-primary tap-target"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Falar no WhatsApp sobre ${area.name}`}
				>
					<i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
					Falar no WhatsApp
				</a>
				<a href="/" class="btn-secondary tap-target" aria-label="Voltar para página inicial">
					Voltar para Home
				</a>
			</div>
		</div>
	</section>

	<section class="content-page" aria-label={`Conteúdo de ${area.name}`}>
		<div class="container content-rich">
			{area.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
			<a class="back-home-link tap-target" href="/">
				<i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
				Voltar para a página inicial
			</a>
		</div>
	</section>

	<section id="faq" class="contact" aria-label={`Perguntas frequentes sobre ${area.name}`}>
		<div class="container">
			<h2 class="section-title reveal">Perguntas Frequentes sobre {area.name}</h2>
			<p class="section-subtitle reveal">Respostas rápidas para dúvidas comuns nessa área de atuação.</p>
			<div class="faq-list">
				{area.faqs.map((faq) => (
					<article class="faq-item reveal">
						<button class="faq-question tap-target" type="button" aria-expanded="false">
							{faq.question}
							<i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
						</button>
						<div class="faq-answer">
							<p>{faq.answer}</p>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="contact" aria-label="Chamada para contato">
		<div class="container">
			<aside class="contact-cta-card reveal" style="max-width: 700px; margin: 0 auto;">
				<h3>Precisa de atendimento em {area.name}?</h3>
				<p>
					Nossa equipe está pronta para analisar seu caso com agilidade, sigilo e estratégia jurídica. Fale agora com
					um advogado.
				</p>
				<a
					href={`https://wa.me/5535998481800?text=${whatsappFromAreaPageMessage}`}
					class="btn-primary tap-target"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Falar no WhatsApp sobre ${area.name}`}
				>
					<i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
					Falar no WhatsApp
				</a>
				<a class="contact-call tap-target" href="tel:+5535998481800" aria-label="Ligar para o escritório">
					<i class="fa-solid fa-phone" aria-hidden="true"></i>
					(35) 99848-1800
				</a>
			</aside>
		</div>
	</section>
</Layout>
