---
import Layout from '../layouts/Layout.astro';

interface TeamProfile {
	slug: string;
	name: string;
	oab?: string;
	role: string;
	title: string;
	description: string;
	image: string;
	imageWidth?: number;
	imageHeight?: number;
	imageAlt: string;
	kicker: string;
	intro: string;
	paragraphs: string[];
	specialties: string[];
}

interface Props {
	profile: TeamProfile;
}

const { profile } = Astro.props;
const schemaJobTitle = profile.role.split('·')[0].trim();
const profileUrl = `https://silveiraadv.com.br/equipe/${profile.slug}`;
const hasOab = typeof profile.oab === 'string' && profile.oab.trim().length > 0;
const whatsappMessage = encodeURIComponent(`Olá! Gostaria de agendar atendimento com ${profile.name}`);

const personSchema: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': `${profileUrl}#person`,
	name: profile.name,
	jobTitle: schemaJobTitle,
	worksFor: {
		'@type': 'LegalService',
		name: 'Silveira Advocacia',
	},
	url: profileUrl,
	knowsAbout: profile.specialties,
};

if (hasOab) {
	personSchema.identifier = profile.oab;
}

const structuredData = [
	personSchema,
	{
		'@context': 'https://schema.org',
		'@type': 'ProfilePage',
		url: profileUrl,
		mainEntity: { '@id': `${profileUrl}#person` },
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Início', item: 'https://silveiraadv.com.br/' },
			{
				'@type': 'ListItem',
				position: 2,
				name: 'Equipe',
				item: 'https://silveiraadv.com.br/equipe',
			},
			{
				'@type': 'ListItem',
				position: 3,
				name: profile.name,
				item: profileUrl,
			},
		],
	},
];
---

<Layout
	title={profile.title}
	description={profile.description}
	canonicalPath={`/equipe/${profile.slug}`}
	structuredData={structuredData}
>
	<section class="page-hero" aria-labelledby="profile-name">
		<div class="container">
			<div class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Início</a>
				<span>/</span>
				<span>Equipe</span>
				<span>/</span>
				<span>{profile.name}</span>
			</div>
			<p class="page-kicker">{profile.kicker}</p>
			<h1 id="profile-name">{profile.name}</h1>
			<p>{profile.role}{hasOab ? ` · ${profile.oab}` : ''}</p>
			<div class="page-actions">
				<a
					href={`https://wa.me/5535998481800?text=${whatsappMessage}`}
					class="btn-primary tap-target"
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`Falar no WhatsApp com a equipe sobre ${profile.name}`}
				>
					<i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
					Agendar Atendimento
				</a>
				<a href="/" class="btn-secondary tap-target">Voltar para Home</a>
			</div>
		</div>
	</section>

	<section class="team" aria-label={`Perfil profissional de ${profile.name}`}>
		<div class="container about-grid" style="align-items: start;">
			<article class="team-card reveal" style="max-width: 100%;">
				<div class="lawyer-photo">
					<img
						src={profile.image}
						alt={profile.imageAlt}
						loading="lazy"
						decoding="async"
						width={profile.imageWidth}
						height={profile.imageHeight}
					/>
				</div>
				<div class="team-content">
					<span class="founder-badge">Perfil Profissional</span>
					<h2 style="font-size: clamp(28px, 3.5vw, 42px);">{profile.name}</h2>
					{hasOab && <p class="team-oab">{profile.oab}</p>}
					<div class="chip-group">
						{profile.specialties.map((specialty) => <span class="chip">{specialty}</span>)}
					</div>
					<p>{profile.intro}</p>
				</div>
			</article>

			<div class="content-rich reveal">
				{profile.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
				<a class="back-home-link tap-target" href="/">
					<i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
					Voltar para a página inicial
				</a>
			</div>
		</div>
	</section>
</Layout>
