---
import Layout from '../../layouts/Layout.astro';

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: 'Equipe Silveira Advocacia',
		url: 'https://silveiraadv.com.br/equipe',
		description:
			'Conheça os advogados da Silveira Advocacia em Campo Belo MG, com atuação em direito criminal, cível, bancário, imobiliário e família.',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Início', item: 'https://silveiraadv.com.br/' },
			{ '@type': 'ListItem', position: 2, name: 'Equipe', item: 'https://silveiraadv.com.br/equipe' },
		],
	},
];
---

<Layout
	title="Equipe em Campo Belo MG | Silveira Advocacia"
	description="Conheça a equipe da Silveira Advocacia em Campo Belo MG e acesse o perfil completo de cada advogado."
	canonicalPath="/equipe"
	structuredData={structuredData}
>
	<section class="page-hero" aria-labelledby="team-title">
		<div class="container">
			<div class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Início</a>
				<span>/</span>
				<span>Equipe</span>
			</div>
			<p class="page-kicker">NOSSO TIME JURÍDICO</p>
			<h1 id="team-title">Conheça Nossa Equipe</h1>
			<p>
				Advogados com atuação estratégica e atendimento humanizado em Campo Belo/MG e online em todo o Brasil.
			</p>
		</div>
	</section>

	<section class="team" aria-label="Advogados da Silveira Advocacia">
		<div class="container">
			<h2 class="section-title reveal">Advogados da Silveira Advocacia</h2>
			<p class="section-subtitle reveal">
				Clique no perfil para conhecer a trajetória, áreas de atuação e diferenciais de cada profissional.
			</p>

			<div class="team-grid">
				<article class="team-card reveal">
					<div class="lawyer-photo">
						<img
							src="/images/advgadoRicard.jpeg"
							alt="Dr. Richard Silveira - Advogado Criminal OAB/MG 114.608"
							loading="lazy"
						/>
					</div>
					<div class="team-content">
						<span class="founder-badge">Sócio Fundador</span>
						<h3>Dr. Richard Silveira</h3>
						<p class="team-oab">OAB/MG 114.608</p>
						<div class="chip-group">
							<span class="chip">Criminal</span>
							<span class="chip">Cível</span>
							<span class="chip">Família</span>
						</div>
						<p>
							Fundador do escritório em 2008, referência em direito criminal em Campo Belo/MG e com atuação
							multidisciplinar em casos estratégicos.
						</p>
						<a class="area-link tap-target" href="/equipe/richard-silveira">Ver perfil completo →</a>
					</div>
				</article>

				<article class="team-card reveal">
					<div class="lawyer-photo">
						<img
							src="/images/AdvogadoRaphael.jpeg"
							alt="Dr. Raphael Marques - Advogado OAB/MG 231.188"
							loading="lazy"
						/>
					</div>
					<div class="team-content">
						<h3>Dr. Raphael Marques</h3>
						<p class="team-oab">OAB/MG 231.188</p>
						<div class="chip-group">
							<span class="chip">Cível</span>
							<span class="chip">Bancário</span>
							<span class="chip">Imobiliário</span>
							<span class="chip">Consumidor</span>
						</div>
						<p>
							Especialista em direito cível e relações de consumo, com atuação técnica em demandas bancárias,
							imobiliárias e sucessórias.
						</p>
						<a class="area-link tap-target" href="/equipe/raphael-marques">Ver perfil completo →</a>
					</div>
				</article>

				<article class="team-card reveal">
					<div class="lawyer-photo">
						<img src="/images/advogadoDiogo.jpeg" alt="Dr. Diogo Ferreira - Advogado" loading="lazy" />
					</div>
					<div class="team-content">
						<h3>Dr. Diogo Ferreira</h3>
						<p class="team-oab">[OAB/MG XXXXX]</p>
						<div class="chip-group">
							<span class="chip">Possessório</span>
							<span class="chip">Empresarial</span>
							<span class="chip">Cível</span>
							<span class="chip">Sucessões</span>
						</div>
						<p>
							Atuação em conflitos patrimoniais, direito possessório e empresarial, com abordagem prática e
							foco em segurança jurídica.
						</p>
						<a class="area-link tap-target" href="/equipe/diogo-ferreira">Ver perfil completo →</a>
					</div>
				</article>
			</div>
		</div>
	</section>
</Layout>
