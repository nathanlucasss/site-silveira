---
import Layout from '../../layouts/Layout.astro';
import { BLOG_POSTS } from '../../data/blog';

const posts = [...BLOG_POSTS].sort((a, b) => (a.date < b.date ? 1 : -1));
const siteUrl = 'https://silveiraadv.com.br';

const AUTHOR_PROFILE_URL_BY_NAME: Record<string, string> = {
	'Dr. Richard Silveira': `${siteUrl}/equipe/richard-silveira`,
	'Dr. Raphael Marques': `${siteUrl}/equipe/raphael-marques`,
	'Dr. Diogo Ferreira': `${siteUrl}/equipe/diogo-ferreira`,
};

const toSchemaAuthor = (authorName: string) => ({
	'@type': 'Person',
	name: authorName.replace(/^Dr\.?\s+/i, '').trim(),
	url: AUTHOR_PROFILE_URL_BY_NAME[authorName] ?? `${siteUrl}/equipe`,
});

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Blog',
	name: 'Blog Silveira Advocacia',
	url: `${siteUrl}/blog`,
	description: 'Artigos jurídicos da Silveira Advocacia sobre temas práticos do dia a dia.',
	blogPost: posts.map((post) => ({
		'@type': 'BlogPosting',
		headline: post.title,
		datePublished: `${post.date}T12:00:00-03:00`,
		dateModified: `${post.date}T12:00:00-03:00`,
		author: toSchemaAuthor(post.author),
		url: `${siteUrl}/blog/${post.slug}`,
	})),
};

function formatDate(value: string) {
	return new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }).format(
		new Date(`${value}T12:00:00`)
	);
}
---

<Layout
	title="Blog em Campo Belo MG | Silveira Advocacia"
	description="Blog jurídico da Silveira Advocacia em Campo Belo MG com orientações sobre direito criminal, cível, família, inventário e dívidas, com linguagem objetiva."
	canonicalPath="/blog"
	structuredData={structuredData}
>
	<section class="page-hero" aria-labelledby="blog-title">
		<div class="container">
			<div class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Início</a>
				<span>/</span>
				<span>Blog</span>
			</div>
			<p class="page-kicker">CONTEÚDO JURÍDICO</p>
			<h1 id="blog-title">Blog da Silveira Advocacia</h1>
			<p>
				Artigos com orientações objetivas sobre temas jurídicos relevantes para quem busca segurança e decisões mais
				bem informadas em Campo Belo/MG.
			</p>
		</div>
	</section>

	<section class="content-page" aria-label="Listagem de artigos">
		<div class="container">
			<div class="blog-grid">
				{posts.map((post) => (
					<article class="area-card blog-card reveal">
						<span class="post-meta">
							<span>{post.category}</span>
							<span>{post.readTime}</span>
						</span>
						<h2 style="font-size: clamp(28px, 3vw, 34px); margin-bottom: 10px;">{post.title}</h2>
						<p style="margin-bottom: 10px;">{post.description}</p>
						<p style="font-size: 14px; color: var(--color-gray-mid); margin-bottom: 14px;">
							Publicado em {formatDate(post.date)}
						</p>
						<a class="area-link tap-target" href={`/blog/${post.slug}`}>Ler artigo completo →</a>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>
