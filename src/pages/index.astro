---
import Layout from '../layouts/Layout.astro';
import { LOCAL_BUSINESS_LEGAL_SERVICE_SCHEMA } from '../data/structuredData';

const homeStructuredData = [
	LOCAL_BUSINESS_LEGAL_SERVICE_SCHEMA,
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: [
			{
				'@type': 'Question',
				name: 'O que fazer se fui preso em flagrante?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Se você ou um familiar foi preso em flagrante, o primeiro e mais importante passo é contatar imediatamente um advogado criminalista. O advogado irá acompanhar a lavratura do auto de prisão em flagrante, verificar a legalidade da prisão e atuar na audiência de custódia, que deve ocorrer em até 24 horas, para pleitear a liberdade ou melhores condições de prisão. Não espere: ligue agora para a Silveira Advocacia, (35) 99848-1800.',
				},
			},
			{
				'@type': 'Question',
				name: 'Quanto custa um advogado criminal em Campo Belo?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Os honorários advocatícios variam de acordo com a complexidade do caso, o número de instâncias, a dedicação necessária e o tipo de serviço prestado. Na Silveira Advocacia, oferecemos uma avaliação inicial do caso para entender a situação e apresentar uma proposta justa e transparente. Entre em contato pelo WhatsApp para conversar sem compromisso.',
				},
			},
			{
				'@type': 'Question',
				name: 'Como funciona o inventário judicial?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'O inventário é o processo legal de levantamento, avaliação e partilha dos bens deixados por uma pessoa falecida. O prazo para abertura é de 60 dias após o óbito. Pode ser feito de forma extrajudicial (cartório, mais rápido, quando não há menores envolvidos e todos os herdeiros concordam) ou judicial (quando há conflito). A Silveira Advocacia atua com celeridade em ambas as modalidades.',
				},
			},
			{
				'@type': 'Question',
				name: 'O escritório atende clientes fora de Campo Belo?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Sim! Oferecemos atendimento 100% online para clientes em qualquer cidade do Brasil. As reuniões são feitas por videochamada, os documentos são assinados digitalmente e o acompanhamento processual é feito de forma remota. Não importa onde você esteja, podemos te atender.',
				},
			},
			{
				'@type': 'Question',
				name: 'O que é usucapião e qual o prazo?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Usucapião é o direito de adquirir a propriedade de um bem pelo uso prolongado e ininterrupto, desde que preenchidos os requisitos legais. Os prazos variam: usucapião ordinária exige 10 anos de posse; a extraordinária exige 15 anos; a especial urbana ou rural exige 5 anos em condições específicas. A Silveira Advocacia analisa cada caso para identificar o melhor caminho.',
				},
			},
			{
				'@type': 'Question',
				name: 'Como funciona a renegociação de dívidas bancárias?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'O processo envolve a análise do contrato e do histórico da dívida para identificar irregularidades, como juros abusivos, capitalização indevida e cobranças ilícitas, seguida de negociação direta com o banco ou credores. Em muitos casos, é possível reduzir significativamente o valor total da dívida. Entre em contato para uma análise.',
				},
			},
		],
	},
];
---

<Layout
